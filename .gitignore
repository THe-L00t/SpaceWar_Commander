# ==========================================================
#  SpaceWar Commander — .gitignore
#
#  원칙: 빌드가 만들어내는 "폴더"를 통째로 무시한다.
#        에셋 포맷(.obj .fbx .png .dds .wav .bank 등)은 무시하지 않는다.
#        → 빌드 폴더만 제외하므로 assets 안의 모델 .obj 는 그대로 남는다.
# ==========================================================

# ── Visual Studio 작업 / 캐시 폴더 ──
.vs/
ipch/

# ── 빌드 출력 · 중간 파일 폴더 (.obj .pdb .ilk .exe 등이 여기 쌓임) ──
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww]in32/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/
[Bb]uild/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# ── VS 개인 설정 파일 (에셋 확장자와 안 겹치는 것만 확장자로 제외) ──
*.user
*.suo
*.VC.db
*.VC.VC.opendb
*.aps
*.ncb

# ── 패키지 캐시 (사용 시) ──
packages/
vcpkg_installed/

# ── OS 잡파일 ──
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# ==========================================================
#  참고: 서드파티 SDK(FMOD·Assimp 등)를 저장소에 커밋한다면,
#  그 안의  x64/ · bin/ · lib/  폴더가 위 규칙에 걸려 무시될 수 있음.
#  그 경우 해당 파일은  `git add -f <경로>` 로 강제 추가하거나
#  external/ 경로에 맞는 예외 규칙(!)을 따로 추가할 것.
# ==========================================================
